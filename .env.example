# Telegram Bot Token (обязательно)
# Получить: https://t.me/BotFather
TELEGRAM_TOKEN=

# OpenRouter API Key (обязательно)
# Получить: https://openrouter.ai/
OPENROUTER_API_KEY=

# Dots Bot Token (если не задан — используется TELEGRAM_TOKEN)
